# Heavy benchmarking assets, downloaded/generated at runtime by Benchmarking
# and Generator. Kept out of git: only the per-corpus README.md files
# are tracked.
src/main/resources/benchmarking/corpora/**
!src/main/resources/benchmarking/corpora/*/
!src/main/resources/benchmarking/corpora/*/README.md

# Scratch area used while benchmarks run.
src/main/resources/benchmarking/sandbox/testing/
